APP_URL=http://localhost:3000
DATABASE_URL=postgresql://gallery:gallery@localhost:5432/gallery?schema=public
REDIS_URL=redis://localhost:6379
AUTH_COOKIE_SECRET=replace-with-at-least-32-random-characters
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET_ORIGINALS=gallery-originals
S3_BUCKET_DERIVATIVES=gallery-derivatives
IMPORTS_PREFIX=imports/
IMPORTS_CLEANUP_MODE=delete
IMPORTS_ARCHIVE_PREFIX=processed-imports/
STORAGE_WEBHOOK_SECRET=
STORAGE_WEBHOOK_SIGNATURE_HEADER=x-storage-webhook-signature
SEED_ADMIN_NAME=Studio Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-before-production

# Optional overrides for docker-compose.server.yml when using external services
# SERVER_DATABASE_URL=postgresql://gallery:change-me@db:5432/gallery?schema=public
# SERVER_REDIS_URL=redis://redis:6379

# Required for any non-local deployment
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://gallery:gallery@localhost:5432/gallery?schema=public
REDIS_URL=redis://localhost:6379
AUTH_COOKIE_SECRET=replace-with-at-least-32-random-characters

# Bootstrap storage config.
# Credentials stay in env in this phase.
# Endpoint, bucket, import, and public-behavior settings can be changed later in /admin/settings.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET_ORIGINALS=gallery-originals
S3_BUCKET_DERIVATIVES=gallery-derivatives
IMPORTS_PREFIX=imports/
IMPORTS_CLEANUP_MODE=delete
IMPORTS_ARCHIVE_PREFIX=processed-imports/

# Optional: leave blank to disable signed webhook verification
STORAGE_WEBHOOK_SECRET=
STORAGE_WEBHOOK_SIGNATURE_HEADER=x-storage-webhook-signature

# Optional Furtrack tag import support.
# Bearer JWT can stay blank; admins can save an encrypted token from the Furtrack match page.
# The published web image includes curl_cffi for browser-like TLS impersonation.
FURTRACK_AUTH_TOKEN=
FURTRACK_BASE_URL=https://solar.furtrack.com
FURTRACK_FETCH_MODE=auto
FURTRACK_CURL_CFFI_COMMAND=python3
FURTRACK_CURL_CFFI_SCRIPT=scripts/furtrack_fetch.py
FURTRACK_CURL_CFFI_IMPERSONATE=chrome

# Optional: leave blank to skip admin creation during seed
SEED_ADMIN_NAME=Studio Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-before-production

# Optional overrides for docker-compose.server.yml when using external services.
# Leave blank or unset to use the bundled db/redis services from the server compose file.
# SERVER_DATABASE_URL=postgresql://gallery:change-me@db:5432/gallery?schema=public
# SERVER_REDIS_URL=redis://redis:6379
